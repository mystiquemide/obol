# ── Database (Neon Postgres) ──
# Pooled connection for app runtime
DATABASE_URL="postgresql://user:pass@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Direct (non-pooled) connection for Prisma migrations — same host without "-pooler"
DIRECT_URL="postgresql://user:pass@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# ── Agent LLM (artist disambiguation) ──
# Provider auto-selects: Groq if GROQ_API_KEY is set, else Anthropic.
# Get a free Groq key at console.groq.com (no card, generous free tier).
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
# LLM_PROVIDER="groq"      # force: groq | anthropic
# MOCK_LLM="false"         # "true" bypasses the network call (testing only)
ANTHROPIC_API_KEY=""       # optional fallback
# ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# ── Circle (Developer Controlled Wallets, Arc Testnet) ──
CIRCLE_API_KEY=""
CIRCLE_ENTITY_SECRET=""

# ── Navidrome / Subsonic (optional — demo mode works without it) ──
NAVIDROME_URL="http://localhost:4533"
NAVIDROME_USER=""
NAVIDROME_PASS=""

# ── Cron protection (set in production) ──
CRON_SECRET=""

# ── App ──
NEXT_PUBLIC_APP_NAME="Obol"
